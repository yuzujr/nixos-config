#!/usr/bin/env bash
set -euo pipefail

NIRI_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/niri"
PROFILES_DIR="$NIRI_DIR/profiles"

CURRENT_CONFIG="$PROFILES_DIR/current-config.kdl"
CURRENT_OUTPUTS="$PROFILES_DIR/current-outputs.kdl"
CURRENT_STARTUP="$PROFILES_DIR/current-startup.kdl"

mode="${1:-}"

die() {
  echo "ERROR: $*" >&2
  exit 1
}
log() { echo "[niri-mode] $*"; }

require_file() { [[ -f "$1" ]] || die "missing file: $1"; }

# ---- root runner ----
run_root() {
  if [[ ${EUID:-999} -eq 0 ]]; then
    "$@"
    return
  fi

  if command -v sudo >/dev/null 2>&1; then
    sudo "$@"
    return
  fi

  die "need root privileges (install sudo or run as root)"
}

# ---- profile links ----
set_links() {
  local profile="$1" # normal|travel
  local base="$PROFILES_DIR/$profile"

  require_file "$base/config.kdl"
  require_file "$base/outputs.kdl"
  require_file "$base/startup.kdl"

  ln -sf "$profile/config.kdl" "$CURRENT_CONFIG"
  ln -sf "$profile/outputs.kdl" "$CURRENT_OUTPUTS"
  ln -sf "$profile/startup.kdl" "$CURRENT_STARTUP"

  log "links -> $profile (config/outputs/startup)"
}

quit_niri() {
  if command -v niri >/dev/null 2>&1; then
    niri msg action quit --skip-confirmation || true
  fi
}

set_power_profile() {
  local profile="$1" # balanced|power-saver|performance
  if command -v powerprofilesctl >/dev/null 2>&1; then
    if powerprofilesctl set "$profile"; then
      log "power profile -> $profile"
    else
      log "failed to set power profile: $profile"
    fi
  else
    log "powerprofilesctl not found; skip power profile change"
  fi
}

unit_exists() {
  local unit="$1"
  local state
  state=$(systemctl --user show -p LoadState --value "$unit" 2>/dev/null || true)
  [[ "$state" != "not-found" && -n "$state" ]]
}

system_unit_exists() {
  local unit="$1"
  local state
  state=$(systemctl show -p LoadState --value "$unit" 2>/dev/null || true)
  [[ "$state" != "not-found" && -n "$state" ]]
}

enable_system_units() {
  local unit
  for unit in "$@"; do
    if system_unit_exists "$unit"; then
      run_root systemctl enable --now "$unit"
      log "enabled system unit: $unit"
    else
      log "system unit not found: $unit (skip)"
    fi
  done
}

disable_system_units() {
  local unit
  for unit in "$@"; do
    if system_unit_exists "$unit"; then
      run_root systemctl disable --now "$unit"
      log "disabled system unit: $unit"
    else
      log "system unit not found: $unit (skip)"
    fi
  done
}

enable_units() {
  local unit
  for unit in "$@"; do
    if unit_exists "$unit"; then
      systemctl --user enable "$unit"
      log "enabled user unit: $unit"
    else
      log "user unit not found: $unit (skip)"
    fi
  done
}

disable_units() {
  local unit
  for unit in "$@"; do
    if unit_exists "$unit"; then
      systemctl --user disable "$unit"
      log "disabled user unit: $unit"
    else
      log "user unit not found: $unit (skip)"
    fi
  done
}

mask_unit() {
  systemctl --user mask --now "$@"
  log "masked services: $*"
}

unmask_unit() {
  systemctl --user unmask "$@"
  log "unmasked services: $*"
}

apply_mode() {
  local profile="$1"

  if [[ "$profile" == "normal" ]]; then
    set_power_profile balanced

    enable_system_units \
      nvidia-powerd.service

    enable_units \
      wl-clip-persist.service \
      sunshine.service

  elif [[ "$profile" == "travel" ]]; then
    set_power_profile power-saver

    disable_system_units \
      nvidia-powerd.service

    disable_units \
      wl-clip-persist.service \
      sunshine.service

  else
    die "unknown profile: $profile"
  fi

  set_links "$profile"
  quit_niri
}

get_current_mode() {
  if [[ -L "$CURRENT_CONFIG" ]]; then
    local target
    target=$(readlink "$CURRENT_CONFIG")
    if [[ "$target" == travel/* ]]; then
      echo "travel"
    elif [[ "$target" == normal/* ]]; then
      echo "normal"
    else
      echo "unknown"
    fi
  else
    echo "unknown"
  fi
}

show_status() {
  log "current mode: $(get_current_mode)"
}

usage() {
  cat <<EOF
Usage: $0 normal|travel|toggle|status
EOF
  exit 2
}

case "$mode" in
travel) apply_mode travel ;;
normal) apply_mode normal ;;
toggle)
  current="$(get_current_mode)"
  log "current mode: $current"
  case "$current" in
  travel) apply_mode normal ;;
  normal) apply_mode travel ;;
  *) die "cannot toggle: current mode is unknown. Run 'status' first." ;;
  esac
  ;;
status) show_status ;;
*) usage ;;
esac
