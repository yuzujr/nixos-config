# Gold API history config template
# Real secret file should come from the agenix-managed runtime path.

API_KEY="REPLACE_ME"
API_URL="https://api.gold-api.com/history"
SYMBOL="XAU"
GROUP_BY="day"
AGGREGATION="avg"
ORDER_BY="asc"
OUTPUT_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/gold-price-history/daily.csv"
